# Copy to `.env` and fill in values.

PAYLOAD_SECRET=
# DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/butcher-shop-3
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
COMPANY_NAME="Payload Inc."
TWITTER_CREATOR="@payloadcms"
TWITTER_SITE="https://nextjs.org/commerce"
SITE_NAME="Payload Commerce"
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Used to preview drafts
PREVIEW_SECRET=

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOKS_SIGNING_SECRET=

# S3-compatible storage (AWS S3, MinIO, DigitalOcean Spaces, etc.). Leave blank to use local Payload uploads.
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Required for non-AWS hosts (e.g. https://storage.example.com). Omit for standard AWS S3.
S3_ENDPOINT=
# Defaults to true when S3_ENDPOINT is set. Set false only if your provider requires virtual-hosted URLs.
S3_FORCE_PATH_STYLE=
# When uploads go to S3 and URLs work in the app, set true so the storefront stops swapping S3 URLs for Unsplash placeholders.
NEXT_PUBLIC_S3_MEDIA_ENABLED=
# Optional: force Unsplash for any S3-style URL even when NEXT_PUBLIC_S3_MEDIA_ENABLED=true (debug).
NEXT_PUBLIC_MEDIA_PLACEHOLDERS_UNTIL_S3=
