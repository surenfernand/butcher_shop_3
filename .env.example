# Copy to `.env` and fill in values.

# Payload
DATABASE_URL=
PAYLOAD_SECRET=

# Public URL used by the storefront and Better Auth fallbacks
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Better Auth (@payload-auth/better-auth-plugin)
# Generate BETTER_AUTH_SECRET with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Optional: Google OAuth — when BOTH are set, `src/plugins/index.ts` enables
# `socialProviders.google` for Better Auth. Authorized redirect URI in Google Cloud
# console should include: {BETTER_AUTH_URL}/api/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Stripe (ecommerce plugin)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOKS_SIGNING_SECRET=

# Preview
PREVIEW_SECRET=
